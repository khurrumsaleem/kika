{
  "name": "GROUPR",
  "description": "<b>GROUPR</b><br><br>GROUPR generates multigroup cross sections from pointwise ENDF or PENDF data. It reads an ENDF tape and a PENDF tape (from RECONR/BROADR) and produces a GENDF (Grouped ENDF) tape containing multigroup cross sections, group-to-group scattering matrices, and other multigroup quantities needed by reactor physics codes.<br><br>Key features:<br><ul><li>Self-shielded cross sections using the Bondarenko method with user-specified sigma-zero values</li><li>Predefined or custom neutron and photon energy group structures</li><li>Built-in weight functions or analytic flux spectra</li><li>Legendre expansion of scattering matrices to arbitrary order</li><li>Support for all standard reaction types and photon production</li></ul>",
  "tooltip": "Compute multigroup cross sections and group-to-group scattering matrices from ENDF/PENDF data.",
  "cards": [
    {
      "name": "Mandatory",
      "parameters": [
        {
          "name": "nendf",
          "display_name": "endf input tape",
          "type": "int",
          "default": -25,
          "constraints": {
            "min": -99,
            "max": 99
          },
          "help": "<b>'nendf'</b><br><br>Unit for endf tape."
        },
        {
          "name": "npend",
          "display_name": "pendf input tape",
          "type": "int",
          "default": -22,
          "constraints": {
            "min": -99,
            "max": 99
          },
          "help": "<b>'npend'</b><br><br>Unit for input pendf tape."
        },
        {
          "name": "ngout2",
          "display_name": "gendf output tape",
          "type": "int",
          "default": -30,
          "constraints": {
            "min": -99,
            "max": 99
          },
          "help": "<b>'ngout2'</b><br><br>Unit for output gendf tape (new style, always required)."
        },
        {
          "name": "matb",
          "display_name": "Isotope",
          "type": "isotope",
          "default": "U235",
          "help": "<b>'matb'</b><br><br>Material to be processed. Select the isotope and the MAT number will be chosen automatically."
        },
        {
          "name": "ign",
          "display_name": "Neutron group structure",
          "type": "option",
          "default": 3,
          "constraints": {
            "options": [
              {"value": 1, "label": "Custom (read Card 6)"},
              {"value": 2, "label": "CSEWG 239-group"},
              {"value": 3, "label": "LANL 30-group"},
              {"value": 4, "label": "ANL 27-group"},
              {"value": 5, "label": "RRD 50-group"},
              {"value": 6, "label": "GAM-II 68-group"},
              {"value": 7, "label": "CLAW-IV 89-group"},
              {"value": 8, "label": "LANL 70-group"},
              {"value": 9, "label": "CLAW 187-group"},
              {"value": 10, "label": "EPRI-CPM 69-group"},
              {"value": 11, "label": "LANL 618-group"},
              {"value": 12, "label": "SAND-II 640-group"},
              {"value": 13, "label": "LANL 80-group"},
              {"value": 14, "label": "EURLIB 100-group"},
              {"value": 15, "label": "SAND-IIA 640-group"},
              {"value": 16, "label": "VITAMIN-E 174-group"},
              {"value": 17, "label": "VITAMIN-J 175-group"},
              {"value": 19, "label": "SAND-III 89-group"},
              {"value": 20, "label": "UKNDL 69-group"},
              {"value": 21, "label": "TRIPOLI 315-group"},
              {"value": 22, "label": "XMAS 172-group"},
              {"value": 23, "label": "ECCO 1968-group"},
              {"value": 24, "label": "ECCO 33-group"},
              {"value": 25, "label": "ECCO 1968-group (mod)"},
              {"value": 26, "label": "SHEM-CEA 281-group"},
              {"value": 27, "label": "SHEM-CEA/LANL 361-group"},
              {"value": 28, "label": "WIMS 69-group"},
              {"value": 29, "label": "WIMS 172-group"},
              {"value": 30, "label": "SAND-IIa 725-group"},
              {"value": 31, "label": "MPACT 47-group"},
              {"value": 32, "label": "MPACT 51-group"},
              {"value": 33, "label": "MPACT 252-group"},
              {"value": 34, "label": "VITAMIN-J+ 199-group"}
            ]
