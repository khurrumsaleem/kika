          "help": "<b>'temperatures'</b><br><br>Temperatures in Kelvin (ascending order)."
        },
        {
          "name": "sigz",
          "display_name": "Sigma-zero values",
          "type": "multi",
          "default": "1e+10",
          "constraints": {
            "min": 0.0
          },
          "help": "<b>'sigz'</b><br><br>Sigma-zero (background cross section) values in barns (descending order, include infinity=1e10)."
        }
